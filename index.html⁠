/* ═══════════════════════════════════════════════════════════
   音效合成器 (Sound Synthesis with Custom Frequency Mapping)
═══════════════════════════════════════════════════════════ */
class SoundSynth {
  constructor() { 
    this.ctx = null; 
    this.muted = false; 
  }
  _init() {
    if (!this.ctx) {
      try { 
        this.ctx = new (window.AudioContext || window.webkitAudioContext)(); 
      } catch (e) {
        console.error("AudioContext 初始化失敗", e);
      }
    }
  }
  _tone(freq, type, dur, vol = 0.25, endFreq) {
    this._init(); 
    if (!this.ctx || this.muted) return;
    const ctx = this.ctx;
    const o = ctx.createOscillator();
    const g = ctx.createGain();
    o.type = type; 
    o.frequency.setValueAtTime(freq, ctx.currentTime);
    if (endFreq) {
      o.frequency.exponentialRampToValueAtTime(endFreq, ctx.currentTime + dur);
    }
    g.gain.setValueAtTime(vol, ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + dur);
    o.connect(g); 
    g.connect(ctx.destination); 
    o.start(); 
    o.stop(ctx.currentTime + dur + 0.05);
  }
  playWhoosh()  { this._tone(180, "sine",     0.22, 0.18, 900);  }
  playPop()     { this._tone(140, "sine",     0.12, 0.60, 45);   }
  playWhistle() { this._tone(1800,"sine",     0.40, 0.22, 2100); }
  playBuzzer()  { this._tone(110, "sawtooth", 0.50, 0.28, 100);  }
  playAbsScan() { this._tone(800, "square",   0.90, 0.08, 1400); }
  playAbsOk()   { this._tone(880, "sine",     0.50, 0.35);       }
  playAbsFail() { this._tone(300, "triangle", 0.50, 0.35, 150);  }
  playBoo()     { this._tone(90,  "sawtooth", 0.60, 0.25, 70);   }
  playCheer()   { this._tone(330, "sine",     0.40, 0.20, 440);  }
  playCrack()   { this._tone(600, "triangle", 0.15, 0.40, 180);  }
  playLevelUp() {
    this._init(); 
    if (!this.ctx || this.muted) return;
    const ctx = this.ctx;
    [[523, 0], [659, 0.14], [784, 0.28], [1047, 0.45]].forEach(([f, t]) => {
      const o = ctx.createOscillator();
      const g = ctx.createGain();
      o.type = "sine"; 
      o.frequency.value = f;
      g.gain.setValueAtTime(0.3, ctx.currentTime + t);
      g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + t + 0.28);
      o.connect(g); 
      g.connect(ctx.destination);
      o.start(ctx.currentTime + t); 
      o.stop(ctx.currentTime + t + 0.32);
    });
  }
}
const synth = new SoundSynth();

function speak(text, muted) {
  if (muted || !window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = "en-US"; 
  u.rate = 1.35; 
  u.pitch = 0.85;
  window.speechSynthesis.speak(u);
}

/* ═══════════════════════════════════════════════════════════
   幾何凸包演算法 (Convex Hull for Subjective Zone Warping)
═══════════════════════════════════════════════════════════ */
function convexHull(pts) {
  if (pts.length < 3) return pts;
  const s = [...pts].sort((a, b) => a.x !== b.x ? a.x - b.x : a.y - b.y);
  const cross = (o, a, b) => (a.x - o.x) * (b.y - o.y) - (a.y - o.y) * (b.x - o.x);
  const lower = [], upper = [];
  for (const p of s) { 
    while (lower.length >= 2 && cross(lower[lower.length-2], lower[lower.length-1], p) <= 0) {
      lower.pop(); 
    }
    lower.push(p); 
  }
  for (let i = s.length - 1; i >= 0; i--) { 
    while (upper.length >= 2 && cross(upper[upper.length-2], upper[upper.length-1], s[i]) <= 0) {
      upper.pop(); 
    }
    upper.push(s[i]); 
  }
  upper.pop(); 
  return lower.concat(upper);
}

function pointInPolygon(x, y, vs) {
  let inside = false;
  for (let i = 0, j = vs.length - 1; i < vs.length; j = i++) {
    const xi = vs[i].x, yi = vs[i].y, xj = vs[j].x, yj = vs[j].y;
    if ((yi > y) !== (yj > y) && x < (xj - xi) * (y - yi) / (yj - yi) + xi) inside = !inside;
  }
  return inside;
}

