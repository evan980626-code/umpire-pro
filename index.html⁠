  const triggerInningSummary = () => {
    setInningReportData({
      pitchesCount: inningPitchesCount.current,
      strikesCalled: inningStrikesCalled.current,
      ballsCalled: inningBallsCalled.current,
      correctCalls: inningCorrectCalls.current,
      inningXp: inningXpEarned.current,
      hostilityDelta: crowdFavor - startCrowdFavor.current
    });
    setShowInningReport(true);
  };

  const closeInningReportAndContinue = () => {
    setShowInningReport(false);
    inningPitchesCount.current = 0;
    inningStrikesCalled.current = 0;
    inningBallsCalled.current = 0;
    inningCorrectCalls.current = 0;
    inningXpEarned.current = 0;
    startCrowdFavor.current = crowdFavor;

    setOuts(0);    
    outsR.current  = 0;
    setStrikes(0); 
    strikesR.current = 0;
    setBalls(0);   
    ballsR.current   = 0;
    setRunners([false, false, false]);

    setIsTop(t => {
      const newTop = !t;
      isTopR.current = newTop;
      if (!t) {
        setInning(i => { 
          const ni = i + 1; 
          inningR.current = ni; 
          return ni; 
        });
      }
      return newTop;
    });

    rotateBatter();
  };

  const doThreeOuts = () => {
    speak("Three outs! Side retired.", muted);
    triggerInningSummary();
  };

  const doStrikeout = () => {
    const newOuts = outsR.current + 1;
    speak("Strikeout!", muted);
    rotateBatter();
    if (newOuts >= 3) {
      setOuts(3); 
      outsR.current = 3;
      setTimeout(doThreeOuts, 400);
    } else {
      setOuts(newOuts); 
      outsR.current = newOuts;
    }
  };

  const doWalk = () => {
    setRunners(prev => {
      let runs = 0; 
      const nr = [...prev];
      if (!nr[0]) nr[0] = true;
      else if (!nr[1]) { nr[1] = true; nr[0] = false; }
      else if (!nr[2]) { nr[2] = true; nr[1] = false; }
      else runs = 1;
      
      if (runs > 0) {
        if (isTopR.current) {
          setAwayScore(s => s + runs); 
        } else {
          setHomeScore(s => s + runs);
        }
      }
      return nr;
    });
    speak("Walk!", muted);
    rotateBatter();
  };

  /* 🧠 主觀心智好球帶分裂變形機制 */
  const warpZone = (p) => {
    miscallsR.current += 1; 
    setMiscalls(miscallsR.current);
    
    setZVerts(prev => {
      if (prev.length === 4) {
        let best = Infinity, ins = 0;
        for (let i = 0; i < 4; i++) {
          const nx = (i + 1) % 4;
          const mx = (prev[i].x + prev[nx].x) / 2;
          const my = (prev[i].y + prev[nx].y) / 2;
          const d = Math.hypot(mx - p.realX, my - p.realY);
          if (d < best) { 
            best = d; 
            ins = nx; 
          }
        }
        const v = [...prev]; 
        v.splice(ins, 0, { x: p.realX * 0.9, y: p.realY * 0.9 }); 
        return v;
      } else {
        let ci = 0, md = Infinity;
        for (let i = 0; i < prev.length; i++) {
          const d = Math.hypot(prev[i].x - p.realX, prev[i].y - p.realY);
          if (d < md) { 
            md = d; 
            ci = i; 
          }
        }
        const v = [...prev];
        const mixRatio = 0.65;
        v[ci] = { x: v[ci].x * (1 - mixRatio) + p.realX * mixRatio, y: v[ci].y * (1 - mixRatio) + p.realY * mixRatio };
        if (v.length < 8 && Math.random() < 0.5) {
          v.push({ x: p.realX * 0.85, y: p.realY * 0.85 });
          return convexHull(v);
        }
        return v;
      }
    });
  };

  /* 投球物理模擬與進壘路徑計算 */
  const startPitch = () => {
    if (phaseR.current !== "ready" || lockedR.current) return;
    setLocked(true); 
    lockedR.current = true;
    setZoneHidden(true); 
    setFb({ text: "🔒 好球帶隱形！捕手手套下滑蓄力中…", type: "pulse" });
    setPhase("ready_fading"); 
    phaseR.current = "ready_fading";
    
    const t0 = Date.now();
    const loop = () => {
      const p = Math.min(1.0, (Date.now() - t0) / 200);
      setFadeP(p);
      if (p < 1.0) {
        requestAnimationFrame(loop); 
      } else {
        executePitch();
      }
    };
    requestAnimationFrame(loop);
  };
  startPitchR.current = startPitch;

  const executePitch = () => {
    let type = PITCH_TYPES[Math.floor(Math.random() * PITCH_TYPES.length)];
    let activeCatcher = catcher;

    if (activeExam === "exam_fastball") {
      const fbs = PITCH_TYPES.filter(t => t.abbr === "FB" || t.abbr === "SI");
      type = fbs[Math.floor(Math.random() * fbs.length)] || PITCH_TYPES[0];
    } else if (activeExam === "exam_breaking") {
      const brks = PITCH_TYPES.filter(t => t.abbr === "CB" || t.abbr === "SL");
      type = brks[Math.floor(Math.random() * brks.length)] || PITCH_TYPES[3];
    } else if (activeExam === "exam_framing") {
      activeCatcher = CATCHERS.find(c => c.name === "莫里納") || catcher;
    }

    const { tB, bB } = batter;
    const cY = (tB + bB) / 2;
    const eff = 1.0 + zoneMargin;
    
    const isExam = activeExam !== "free";
    const isStrikeTarget = Math.random() < 0.44;
    let x = 0, y = cY;

    if (isExam || Math.random() < 0.7) {
      const side = Math.floor(Math.random() * 4);
      const mo = (Math.random() - 0.5) * 0.08; 
      if      (side === 0) { x = -eff + mo;              y = tB + Math.random() * (bB - tB); }
      else if (side === 1) { x =  eff + mo;              y = tB + Math.random() * (bB - tB); }
      else if (side === 2) { x = (Math.random()-0.5)*1.6; y = tB - zoneMargin + mo; }
      else                 { x = (Math.random()-0.5)*1.6; y = bB + zoneMargin + mo; }
    } else {
      if (isStrikeTarget) {
        x = (Math.random()-0.5)*1.4; 
        y = cY + (Math.random()-0.5)*(bB-tB)*0.7;
      } else {
        const side = Math.floor(Math.random() * 4);
        const out = 0.25 + Math.random() * 0.55;
        if      (side === 0) { x = -eff - out; y = cY + (Math.random()-0.5)*1.6; }
        else if (side === 1) { x =  eff + out; y = cY + (Math.random()-0.5)*1.6; }
        else if (side === 2) { x = (Math.random()-0.5)*2.2; y = tB - zoneMargin - out; }
        else                 { x = (Math.random()-0.5)*2.2; y = bB + zoneMargin + out; }
      }
    }

    const ex = (Math.random()-0.5) * pitcher.err * 1.8;
    const ey = (Math.random()-0.5) * pitcher.err * 1.1;

    const windOffsetX = wind.x * 0.45;
    const windOffsetY = wind.y * 0.35;

    x = x * 0.45 + ctarget.x * 0.55 + ex + windOffsetX;
    y = y * 0.45 + ctarget.y * 0.55 + ey + windOffsetY;

    const isStrike = Math.abs(x) <= eff && y >= tB-zoneMargin && y <= bB+zoneMargin;
    const isEdge   = Math.abs(Math.abs(x)-eff)<0.22 || Math.abs(y-(tB-zoneMargin))<0.22 || Math.abs(y-(bB+zoneMargin))<0.22;
    const isCU     = Math.hypot(x-ctarget.x, y-ctarget.y) > 0.95;
    setCrossUp(isCU);

    let fX = x, fY = y, fk = "normal";
    
    if (isCU) {
      if (Math.random() < 0.12) {
        fk = "lucky_save";
        const pull = 0.45 * activeCatcher.fm;
        fX = x - x * pull; 
        fY = y + (cY - y) * pull;
      } else {
        const rx = x > ctarget.x ? 1 : -1;
        const ry = y > ctarget.y ? 1 : -1;
        const rc = 0.26 * (1.0 / activeCatcher.fm);
        fX = x + rx * rc; 
        fY = y + ry * rc;
      }
    } else if (activeCatcher.name === "桑契斯") {
      fk = "stab_ruined";
      const bounceX = x > 0 ? 0.24 : -0.24;
      const bounceY = y > cY ? 0.22 : -0.22;
      fX = x + bounceX;
      fY = y + bounceY;
    } else {
      const pull = (isEdge ? 0.38 : 0.16) * activeCatcher.fm;
      fX = x - x * pull; 
      fY = y + (cY - y) * pull;
    }

    const speed = Math.round((type.spd[0]+Math.random()*(type.spd[1]-type.spd[0]))*pitcher.sMult);
    const spin  = Math.round(type.spin[0]+Math.random()*(type.spin[1]-type.spin[0]));
    const ms    = (1100 - speed * 4.2);

    const pd = {
      id: Date.now(), type, speed, spin,
      realX: x, realY: y, framedX: fX, framedY: fY,
      isStrike, isEdge, isCU, fluke: fk,
      tB, bB, batter: batter.name, pitcher: pitcher.name, catcher: activeCatcher.name,
    };
    setPitch(pd); 
    setBallProg(0); 
    setBallPos({ x: 0, y: -1.2 });
    setPhase("pitching"); 
    phaseR.current = "pitching";
    synth.playWhoosh();

    const t0 = Date.now();
    const fly = () => {
      const prog = Math.min(1.0, (Date.now()-t0)/ms);
      setBallProg(prog);
      
      setBallPos({
        x: x*prog + (type.brkX/100)*Math.sin(prog*Math.PI) + wind.x*prog*0.25,
        y: -1.2*(1-prog)+y*prog+(type.brkY/100)*Math.sin(prog*Math.PI) + wind.y*prog*0.25,
      });

      if (prog < 1.0) { 
        requestAnimationFrame(fly); 
        return; 
      }
      
      resolveBatterSwing(pd);
    };
    requestAnimationFrame(fly);
  };

  const resolveBatterSwing = (pitchData) => {
    synth.playPop();
    decisionT.current = Date.now();
    setPhase("decision"); 
    phaseR.current = "decision";
    setLocked(false); 
    lockedR.current = false;
    setZoneHidden(true); 
    
    let msg = "⚾ 請觀察捕手接球點與【手套拖曳位移】，判定好球 (S) 或壞球 (B)。";
    if (pitchData.catcher === "莫里納") msg = "⚾ 頂級防守！莫里納正在將邊界球「揉拉」進好球帶，注意最初落點！";
    else if (pitchData.catcher === "桑契斯") msg = "⚾ 桑契斯接球僵硬！手套反震彈出，請勿被欺騙！";
    setFb({ text: msg, type: "info" });
  };

  /* ⚖️ 判決套用與計算 */
  const applyCall = (isCorrect, callLabel, p, ms, precisionStr) => {
    setZoneHidden(false);

    inningPitchesCount.current += 1;

    if (activeExam !== "free") {
      const nextPitches = examPitches + 1;
      const nextCorrect = isCorrect ? examCorrect + 1 : examCorrect;
      setExamPitches(nextPitches);
      setExamCorrect(nextCorrect);

      if (nextPitches >= 10) {
        const required = EXAMS_LIST.find(e => e.id === activeExam)?.target || 8;
        const passed = nextCorrect >= required;
        setTimeout(() => {
          setShowExamResult({ passed, correct: nextCorrect, total: 10, examId: activeExam });
          if (passed) {
            setUnlockedCerts(prev => {
              if (prev.includes(activeExam)) return prev;
              return [...prev, activeExam];
            });
            // 解鎖對應成就
            unlockAchievement(activeExam);
            synth.playLevelUp();
          } else {
            synth.playBuzzer();
          }
        }, 1200);
      }
    }

    let isConsistent = true;
    if (miscallsR.current > 0 && zVerts.length >= 4) {
      const inSubj = pointInPolygon(p.realX, p.realY, zVerts);
      if (callLabel === "BALL" && inSubj) {
        isConsistent = false;
        setInconsistentCount(c => c + 1);
      }
    }

    let xpD = 0;
    let favorDelta = 0;

    if (isCorrect) {
      inningCorrectCalls.current += 1;
      xpD = p.isEdge ? 30 : 12;
      
      if (precisionStr === "PERFECT 完美時機") {
        xpD += 8;
      }

      const nextStreak = streakR.current + 1;
      setStreak(nextStreak);
      streakR.current = nextStreak;
      const nextCombo = Math.min(3.0, 1.0 + (nextStreak * 0.1));
      setCombo(nextCombo);

      xpD = Math.round(xpD * nextCombo);

      if (nextStreak >= 10) {
        unlockAchievement("perfect_10");
      }

      setRep(r => Math.min(100, r + 4));
      if (nextStreak > bestStreak) setBestStreak(nextStreak);
      speak(p.isStrike ? "Strike!" : "Ball!", muted);

      favorDelta = p.isEdge ? 8 : 4;
      synth.playCheer();
    } else {
      setStreak(0);
      streakR.current = 0;
      setCombo(1.0);

      xpD = p.isEdge ? -6 : -25 - (!isConsistent ? 10 : 0);
      setRep(r => Math.max(0, r - (p.isEdge ? 6 : 16) - (!isConsistent ? 10 : 0)));
      
      if (!p.isEdge) warpZone(p);
      speak("Incorrect call!", muted);

      const isHomeBatter = !isTopR.current;
      let loss = ((isHomeBatter && p.isStrike && callLabel === "BALL") || (!isHomeBatter && !p.isStrike && callLabel === "STRIKE")) ? -18 : -8;
      
      favorDelta = loss;
      if (loss <= -10) {
        setScreenShake(true); 
        setTimeout(() => setScreenShake(false), 500);
        synth.playBoo();
      }
    }

    inningXpEarned.current += xpD;
    setCrowdFavor(f => Math.max(0, Math.min(100, f + favorDelta)));
    setXp(prev => Math.max(0, prev + xpD));

    const entry = { ...p, called: callLabel, isCorrect, xpD, consist: isConsistent, precision: precisionStr };
    setHistory(prev => [entry, ...prev]);

    const consistMsg = !isConsistent ? " ⚠️ 尺度不一！" : "";
    const mainMsg = isCorrect
      ? `✅ 精確！【${p.isStrike?"好球":"壞球"}】${consistMsg} (${precisionStr})`
      : `❌ 誤判！實際為【${p.isStrike?"好球":"壞球"}】${consistMsg}`;
    setFb({ text: mainMsg, type: isCorrect ? "good" : "bad" });

    if (callLabel === "STRIKE") {
      inningStrikesCalled.current += 1;
      if (strikesR.current >= 2) {
        doStrikeout();
      } else {
        const ns = strikesR.current + 1; 
        setStrikes(ns); 
        strikesR.current = ns;
      }
    } else {
      inningBallsCalled.current += 1;
      if (ballsR.current >= 3) {
        doWalk();
      } else {
        const nb = ballsR.current + 1; 
        setBalls(nb); 
        ballsR.current = nb;
      }
    }

    setPhase("outcome"); 
    phaseR.current = "outcome";
    setTimeout(() => {
      setPitch(null);
      setPhase("ready"); 
      phaseR.current = "ready";
      setLocked(false);  
      lockedR.current = false;
    }, 1900);
  };

  const triggerCall = (action) => {
    if (phaseR.current !== "decision" || lockedR.current) return;
    setLocked(true); 
    lockedR.current = true;

    const ms = decisionT.current ? Date.now() - decisionT.current : 0;
    setReactionMs(ms);

    const callLabel  = action === "strike_action" ? "STRIKE" : "BALL";
    const isCorrect  = (action === "strike_action") === pitch.isStrike;
    setRecent(prev => [...prev.slice(-3), pitch]);

    let precisionStr = "NICE CALL";
    if (ms >= 150 && ms <= 450) {
      precisionStr = "PERFECT 完美時機";
    } else if (ms > 1000) {
      precisionStr = "LATE 判定遲疑";
    }

    setActiveCallEffect({
      type: callLabel,
      precision: precisionStr,
      isCorrect: isCorrect
    });

    setTimeout(() => {
      setActiveCallEffect(null);
    }, 1500);

    const challTeam = action === "strike_action"
      ? (isTopR.current ? "away" : "home")
      : (isTopR.current ? "home" : "away");
    const chLeft = challTeam === "away" ? awayCh : homeCh;
    
    const chProb = chLeft > 0 ? (!isCorrect ? 0.40 : pitch.isEdge ? 0.05 : 0) : 0;

    if (Math.random() < chProb) {
      const who = action === "strike_action" ? `打者 ${batter.name}` : `捕手 ${catcher.name}`;
      setChallenge({ call: action, callLabel, isCorrect, ev: pitch, challTeam });
      setAbsP(0); 
      setAbsComplete(false);
      absCompleteR.current = false;
      setAbsVerdict(false); 
      absVerdictR.current = false;
      setPhase("challenge"); 
      phaseR.current = "challenge";
      setLocked(false); 
      lockedR.current = false;
      synth.playWhistle();
      setFb({ text: `🧢 ${who} 啟動 ABS 鷹眼挑戰！`, type: "info" });
      speak("ABS Challenge!", muted);
    } else {
      applyCall(isCorrect, callLabel, pitch, ms, precisionStr);
    }
  };
  triggerCallR.current = triggerCall;

  const confirmChallenge = () => {
    if (!challenge || !absComplete) return;
    const { isCorrect, callLabel, ev, challTeam } = challenge;

    setAbsVerdict(true);
    absVerdictR.current = true;
    
    ev.isStrike ? synth.playAbsOk() : synth.playAbsFail();
    speak(ev.isStrike ? "Strike" : "Ball", muted);

    setTimeout(() => {
      if (isCorrect) {
        if (challTeam === "away") setAwayCh(c => Math.max(0, c-1));
        else                      setHomeCh(c => Math.max(0, c-1));
        setFb({ text: "❌ 挑戰失敗！維持原判。", type: "bad" });
        synth.playBuzzer();
        setTimeout(() => { 
          applyCall(true, callLabel, ev, 500, "AFTER REVIEW"); 
          setChallenge(null); 
          setAbsComplete(false);
          setAbsVerdict(false);
        }, 900);
      } else {
        const overturnedLabel = callLabel === "STRIKE" ? "BALL" : "STRIKE";
        setFb({ text: "✅ 挑戰成功！判決遭推翻，改判。", type: "good" });
        synth.playWhistle();
        setTimeout(() => { 
          applyCall(true, overturnedLabel, ev, 500, "AFTER REVIEW"); 
          setChallenge(null); 
          setAbsComplete(false);
          setAbsVerdict(false);
        }, 900);
      }
    }, 1600); 
  };
  confirmChalR.current = confirmChallenge;

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100 flex flex-col font-sans select-none overflow-x-hidden">
      <style>{`
        @keyframes gloveBreath { 0%,100%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(1.2px) rotate(.35deg)} }
        @keyframes tremor { 0%,100%{transform:translate(0,0)} 25%{transform:translate(-.3px,.3px)} 75%{transform:translate(.3px,-.3px)} }
        .glove-anim { animation: gloveBreath 3.4s ease-in-out infinite, tremor .11s linear infinite; transform-origin:center; }
        @keyframes fadeIn  { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }
        @keyframes ping2   { 0%{transform:scale(1);opacity:1} 80%{transform:scale(1.9);opacity:0} 100%{opacity:0} }
        .fade-in  { animation: fadeIn .3s ease; }
        .ping2    { animation: ping2 .9s cubic-bezier(0,0,.2,1) infinite; }
        .sl-grid  { background-image:linear-gradient(rgba(56,189,248,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(56,189,248,.06) 1px,transparent 1px); background-size:20px 20px; }
        
        @keyframes customShake {
          0%, 100% { transform: translate3d(0, 0, 0); }
          10%, 30%, 50%, 70%, 90% { transform: translate3d(-3px, 1px, 0); }
          20%, 40%, 60%, 80% { transform: translate3d(3px, -1px, 0); }
        }
        .shake-active {
          animation: customShake 0.4s cubic-bezier(.36,.07,.19,.97) both;
          backface-visibility: hidden;
          perspective: 1000px;
        }

        @keyframes callPopUp {
          0% { transform: scale(0.3) rotate(-20deg); opacity: 0; }
          40% { transform: scale(1.2) rotate(8deg); opacity: 1; }
          75% { transform: scale(1.0) rotate(0deg); opacity: 1; }
          100% { transform: scale(0.8) translateY(-15px); opacity: 0; }
        }
        .call-pop-anim { animation: callPopUp 1.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
      `}</style>

      {/* ══ HEADER ══ */}
      <header className="border-b border-slate-800 bg-slate-900/95 sticky top-0 z-50 backdrop-blur shadow-lg">
        <div className="max-w-7xl mx-auto px-4 py-2.5 flex flex-wrap items-center gap-3 justify-between">
          
          {/* Logo */}
          <div className="flex items-center gap-2.5">
            <span className="text-2xl">⚖️</span>
            <div>
              <p className="text-sm font-black bg-gradient-to-r from-amber-400 to-cyan-400 bg-clip-text text-transparent tracking-wider uppercase leading-none">Umpire Pro 8.8</p>
              <p className="text-[9px] text-slate-500 font-mono">MLB ABS Close-Up & Dynamic Pitch System</p>
            </div>
          </div>

          {/* Career XP bar */}
          {screen === "live" && (
            <div className="flex-1 max-w-xs min-w-[120px]">
              <div className="flex justify-between text-[9px] text-slate-400 mb-1">
                <span className="font-bold text-amber-400">{curLvl.title}</span>
                <span>{xp.toLocaleString()} XP</span>
              </div>
              <div className="h-1.5 bg-slate-800 rounded-full overflow-hidden">
                <div className="h-full bg-gradient-to-r from-amber-500 to-cyan-500 rounded-full transition-all duration-700"
                     style={{ width: `${xpFrac * 100}%` }} />
              </div>
            </div>
          )}

          {/* Combo Multiplier indicator */}
          {screen === "live" && combo > 1.0 && (
            <div className="bg-amber-500/10 border border-amber-500/40 px-2.5 py-0.5 rounded-full text-[10px] font-black text-amber-400 animate-pulse font-mono">
              COMBO {combo.toFixed(1)}x
            </div>
          )}

          {/* Notification Alert */}
          {notif && (
            <div className="fade-in text-[11px] font-bold text-amber-400 bg-amber-950/60 border border-amber-700/50 px-3 py-1 rounded-lg">
              {notif}
            </div>
          )}

          {/* Controls */}
          <div className="flex items-center gap-1.5">
            {screen === "live" && (
              <>
                {["game", "scorecard", "settings"].map(t => (
                  <button key={t} onClick={() => setTab(t)}
                    className={`px-3 py-1 rounded-lg text-[11px] font-bold transition ${tab === t ? "bg-amber-500 text-slate-950" : "bg-slate-800 text-slate-300 hover:bg-slate-700"}`}>
