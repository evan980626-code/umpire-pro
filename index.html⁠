                        <span className="text-slate-500 font-mono text-[9px]">速比:{p.sMult} | 阻力:{p.bMult} | 誤差:±{p.err}</span>
                      </button>
                    ))}
                  </div>
                </div>

                {/* Catcher Selection */}
                <div className="space-y-2">
                  <label className="text-[11px] text-slate-400 block font-bold">手動指定防守捕手 (CATCHER)</label>
                  <div className="grid grid-cols-1 sm:grid-cols-2 gap-2">
                    {CATCHERS.map(c => (
                      <button key={c.name} onClick={() => setCatcher(c)}
                        className={`p-2.5 rounded-lg border text-left text-[10px] transition flex flex-col gap-1 ${catcher.name === c.name ? "border-cyan-500 bg-cyan-950/20 text-cyan-300" : "border-slate-800 bg-slate-950 text-slate-400 hover:border-slate-700 hover:text-slate-200"}`}>
                        <span className="font-bold">{c.name}</span>
                        <span className={`text-[9px] ${c.cls} font-mono`}>Framing 偷球技巧: {c.fm}</span>
                      </button>
                    ))}
                  </div>
                </div>

                {/* Career Reset Action */}
                <button onClick={() => {
                  setXp(0); setLvl(0); setRep(100); setStreak(0); setBestStreak(0); setCombo(1.0);
                  setInning(1); setIsTop(true); setOuts(0); setStrikes(0); setBalls(0);
                  setAwayScore(0); setHomeScore(0); setRunners([false, false, false]);
                  setAwayCh(3); setHomeCh(3); setPitch(null); setPhase("ready");
                  phaseR.current = "ready"; setLocked(false); lockedR.current = false;
                  setHistory([]); setRecent([]); setMiscalls(0); miscallsR.current = 0;
                  setZVerts([]); setChallenge(null); setAbsComplete(false); setAbsVerdict(false); setCrowdFavor(50);
                  setAchievements([]); setActiveExam("free"); setUnlockedCerts([]); setInconsistentCount(0);
                }}
                  className="w-full py-3 rounded-xl border border-rose-900 bg-rose-950/20 hover:bg-rose-950/50 text-rose-400 text-[11px] font-black transition shadow-md font-mono">
                  🗑️ 清空所有統計紀錄並重置主審特訓職業生涯 (不保留執照與成就)
                </button>
              </div>
            </div>
          )}

        </div>
      )}
    </div>
  );
}

/* ═══════════════════════════════════════════════════════════
   好球帶 2D 渲染組件 (Zone SVG Renderer - 手套延時拖曳與極簡引導)
═══════════════════════════════════════════════════════════ */
function Zone({ pitch, revealed, ballPos, ballProg, batter, catcher, phase, zoneHidden, zoneMargin, ctarget, crossUp, fluke, fadeP }) {
  const W = 320, H = 360, ZW = 120, ZH = 140, ZY = 90;
  const { tB, bB } = batter;
  const topY = ZY + ZH / 2 + tB * (ZH / 2);
  const bottomY = ZY + ZH / 2 + bB * (ZH / 2);
  const effL = (ZW / 2) * (1 + zoneMargin);
  const effTopY = topY - zoneMargin * (ZH / 2);
  const effBotY = bottomY + zoneMargin * (ZH / 2);

  const tgtX = W / 2 + ctarget.x * (ZW / 2);
  const tgtY = ZY + ZH / 2 + ctarget.y * (ZH / 2);

  let gX = tgtX, gY = tgtY;
  let dX = W / 2, dY = ZY + ZH / 2;

  if (phase === "ready_fading") {
    gX = tgtX; 
    gY = tgtY + (bottomY - tgtY) * fadeP;
    dX = W / 2; 
    dY = ZY + ZH / 2 - 1.2 * (ZH / 2);
  } else if (pitch) {
    const realX_px = W / 2 + pitch.realX * (ZW / 2);
    const realY_px = ZY + ZH / 2 + pitch.realY * (ZH / 2);
    const framedX_px = W / 2 + pitch.framedX * (ZW / 2);
    const framedY_px = ZY + ZH / 2 + pitch.framedY * (ZH / 2);
    const gloveBot = bottomY;

    if (ballProg < 0.88) {
      gX = tgtX; 
      gY = gloveBot;
      dX = W / 2 + (ballPos.x * (ZW / 2)); 
      dY = ZY + ZH / 2 + (ballPos.y * (ZH / 2));
    } else if (ballProg < 0.93) {
      const t = (ballProg - 0.88) / 0.05;
      gX = tgtX + (realX_px - tgtX) * t;
      gY = gloveBot + (realY_px - gloveBot) * t;
      dX = W / 2 + (ballPos.x * (ZW / 2)); 
      dY = ZY + ZH / 2 + (ballPos.y * (ZH / 2));
    } else {
      const t = (ballProg - 0.93) / 0.07;
      gX = realX_px + (framedX_px - realX_px) * t;
      gY = realY_px + (framedY_px - realY_px) * t;
      dX = gX; 
      dY = gY;
    }
  }

  if (phase === "decision" && pitch) {
    gX = W / 2 + pitch.framedX * (ZW / 2);
    gY = ZY + ZH / 2 + pitch.framedY * (ZH / 2);
  }

  const zoneBorderColor = revealed
    ? (pitch?.isStrike ? "#10b981" : "#f43f5e")
    : "rgba(186,230,253,0.75)";

  const currentBallRadius = 1.2 + ballProg * 4.3;
  const isBallVisible = pitch && ballProg > 0 && ballProg < 0.98;

  return (
    <svg width="100%" viewBox={`0 0 ${W} ${H}`} className="block select-none overflow-visible">
      <defs>
        <radialGradient id="bg" cx="50%" cy="40%" r="65%">
          <stop offset="0%" stopColor="#0f172a"/>
          <stop offset="100%" stopColor="#020617"/>
        </radialGradient>
        <linearGradient id="grl" x1="0%" y1="100%" x2="0%" y2="0%">
          <stop offset="0%" stopColor="#064e3b" stopOpacity=".65"/>
          <stop offset="100%" stopColor="#022c22" stopOpacity="0"/>
        </linearGradient>
        <filter id="glow">
          <feGaussianBlur stdDeviation="3" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>

      {/* BG */}
      <rect width={W} height={H} fill="url(#bg)" rx="16"/>

      {/* Dynamic Lights */}
      {[[20, 15, 1], [300, 15, -1]].map(([bx, by, dir], i) => (
        <g key={i} opacity=".35">
          <line x1={bx} y1={by} x2={bx + dir * 8} y2={60} stroke="#475569" strokeWidth="2"/>
          <rect x={bx - 8} y={by - 5} width={16} height={9} fill="#334155" rx="2"/>
          {[-4, 0, 4].map(ox => <circle key={ox} cx={bx+ox} cy={by} r={1.8} fill="#fff" filter="url(#glow)"/>)}
        </g>
      ))}

      {/* Perspective field lines */}
      {Array.from({ length: 11 }).map((_, i) => (
        <line key={i} x1={W / 2} y1={22} x2={W * .03 + W * .94 * (i / 10)} y2={H - 14}
          stroke="rgba(80,120,220,.04)" strokeWidth="1"/>
      ))}

      {/* Turf grass overlay */}
      <path d={`M${W / 2 - 85},${H - 58}L${W / 2 + 85},${H - 58}L${W / 2 + 135},${H}L${W / 2 - 135},${H}Z`} fill="url(#grl)"/>

      {/* Ground Homeplate design */}
      <polygon points={`${W / 2 - 52},${H - 34} ${W / 2 + 52},${H - 34} ${W / 2+52},${H-21} ${W / 2},${H-8} ${W / 2-52},${H-21}`}
        fill="rgba(30,41,59,.7)" stroke="rgba(148,163,184,.4)" strokeWidth="1.5"/>

      {/* Target Crosshair */}
      {phase === "ready" && (
        <g opacity=".45">
          <ellipse cx={tgtX} cy={tgtY} rx="26" ry="22" fill="none" stroke="#fcd34d" strokeWidth="2" strokeDasharray="5,3"/>
          <text x={tgtX} y={tgtY + 4} fontSize="8" fill="#fcd34d" textAnchor="middle" fontWeight="black" fontFamily="sans-serif">TARGET</text>
        </g>
      )}

      {/* Strike Zone Frame Box (zoneHidden 決定宣判前絕對隱形) */}
      <rect x={W / 2 - effL} y={effTopY} width={effL * 2} height={effBotY - effTopY}
        fill="none" stroke={zoneBorderColor} strokeWidth="2"
        opacity={zoneHidden ? 0 : 1}
        style={{ transition: "opacity .12s" }}/>

      <text x={W / 2} y={effTopY - 8} fontSize="8.5" fill="rgba(186,230,253,.35)"
        textAnchor="middle" fontFamily="monospace" letterSpacing="3" fontWeight="bold"
        opacity={zoneHidden ? 0 : 1}>好球帶 ZONE</text>

      {/* Animated Catcher Glove */}
      <g className="glove-anim" style={{ transition: crossUp && ballProg > .85 ? "transform .05s ease-out" : "none" }}>
        <ellipse cx={gX} cy={gY} rx={22} ry={19.5} fill="#4a2c11" stroke="#331c0a" strokeWidth="2"/>
        <circle cx={gX} cy={gY} r={6} fill="rgba(0,0,0,.3)"/>
        <line x1={gX - 12} y1={gY + 8} x2={gX + 12} y2={gY + 8} stroke="#5d3a18" strokeWidth="1.5" strokeLinecap="round"/>
      </g>

      {/* Ball in flight */}
      {isBallVisible && (
        <circle cx={dX} cy={dY} r={currentBallRadius} fill="#fafaf9" stroke="rgba(200,220,255,.5)" strokeWidth={ballProg > .85 ? 0 : 0.8}/>
      )}

      {/* Trajectory lines and dots after call */}
      {revealed && pitch && (
        <g>
          {/* 真實接球點 (黃色高亮準星) */}
          <circle cx={W / 2 + pitch.realX * (ZW / 2)} cy={ZY + ZH / 2 + pitch.realY * (ZH / 2)} r={4.5} fill="none" stroke="#f59e0b" strokeWidth="1.5"/>
          <circle cx={W / 2 + pitch.realX * (ZW / 2)} cy={ZY + ZH / 2 + pitch.realY * (ZH / 2)} r={1.5} fill="#f59e0b"/>
          
          {/* 偷球拖曳路徑 (手套物理扯動線) */}
          <line x1={W / 2 + pitch.realX * (ZW / 2)} y1={ZY + ZH / 2 + pitch.realY * (ZH / 2)}
                x2={W / 2 + pitch.framedX * (ZW / 2)} y2={ZY + ZH / 2 + pitch.framedY * (ZH / 2)}
                stroke="#f59e0b" strokeWidth="1.8" strokeDasharray="3,2" style={{ filter: "drop-shadow(0 0 2px #f59e0b)" }}/>
          
          {/* 最終持球點 (綠色實心) */}
          <circle cx={W / 2 + pitch.framedX * (ZW / 2)} cy={ZY + ZH / 2 + pitch.framedY * (ZH / 2)} r={3.2} fill="#10b981"/>
          
          {/* 真實判定點資訊標籤 */}
          <text x={W / 2 + pitch.realX * (ZW / 2)} y={ZY + ZH / 2 + pitch.realY * (ZH / 2) - 9}
            fontSize="8" textAnchor="middle" fill="#f59e0b" fontWeight="black" fontFamily="sans-serif">
            {pitch.isStrike ? "● 真實好球 (STRIKE)" : "● 真實壞球 (BALL)"}
          </text>

          {/* 顯示扯拉公分數 */}
          <g transform={`translate(${W / 2 + (pitch.realX + pitch.framedX) * (ZW / 4) - 30}, ${ZY + ZH / 2 + (pitch.realY + pitch.framedY) * (ZH / 4) - 6})`}>
            <rect x="0" y="0" width="60" height="11" rx="2" fill="rgba(15,23,42,0.9)" stroke="#faf089" strokeWidth="0.5"/>
            <text x="30" y="8" fontSize="6.5" fill="#faf089" textAnchor="middle" fontFamily="monospace" fontWeight="bold">
              位移 {(Math.hypot(pitch.realX - pitch.framedX, pitch.realY - pitch.framedY) * 21.6).toFixed(1)} cm
            </text>
          </g>
        </g>
      )}
    </svg>
  );
}

/* ═══════════════════════════════════════════════════════════
   電子眼挑戰系統渲染 (ABS Hawk-Eye Renderer with Dynamic Zoom-In)
═══════════════════════════════════════════════════════════ */
function AbsRenderer({ ev, progress, batter, zoneMargin, showVerdict }) {
  const W = 320, H = 360, ZW = 120, ZH = 140, ZY = 90;
  const { tB, bB } = batter;
  const topY = ZY + ZH / 2 + tB * (ZH / 2), bottomY = ZY + ZH / 2 + bB * (ZH / 2);
  const effL = (ZW / 2) * (1 + zoneMargin);
  const effTopY = topY - zoneMargin * (ZH / 2);
  const effBotY = bottomY + zoneMargin * (ZH / 2);

  const finalX = W / 2 + ev.realX * (ZW / 2);
  const finalY = ZY + ZH / 2 + ev.realY * (ZH / 2);

  const pathP = Math.min(1.0, progress * 1.5);
  const pts = [];
  for (let t = 0; t <= pathP; t += 0.05) {
    pts.push({
      x: W / 2 + ((ev.realX * t + (ev.type?.brkX / 100 || 0) * Math.sin(t * Math.PI)) * (ZW / 2)),
      y: ZY + ZH / 2 + ((-1.2 * (1 - t) + ev.realY * t + (ev.type?.brkY / 100 || 0) * Math.sin(t * Math.PI)) * (ZH / 2)),
    });
  }

  let vx = 0, vy = 0, vw = 320, vh = 360;
  const zoomStartProg = 0.72;

  if (progress > zoomStartProg) {
    const t = Math.min(1.0, (progress - zoomStartProg) / (1.0 - zoomStartProg));
    const ease = t * t * (3 - 2 * t);
    
    const targetW = 130;
    const targetH = 146.25;
    const targetX = finalX - targetW / 2;
    const targetY = finalY - targetH / 2;

    vx = 0 + (targetX - 0) * ease;
    vy = 0 + (targetY - 0) * ease;
    vw = 320 + (targetW - 320) * ease;
    vh = 360 + (targetH - 360) * ease;
  }

  let ballRadius = 2.5 + progress * 5.0; 
  if (progress > zoomStartProg) {
    const zoomRatio = (progress - zoomStartProg) / (1.0 - zoomStartProg);
    ballRadius = (2.5 + progress * 5.0) + zoomRatio * 11.5; 
  }

  const bX = pts.length ? pts[pts.length - 1].x : W / 2;
  const bY = pts.length ? pts[pts.length - 1].y : ZY + ZH / 2;

  const done = progress >= 0.98;
  const zFill = showVerdict ? (ev.isStrike ? "rgba(16,185,129,.22)" : "rgba(59,130,246,.18)") : "rgba(56,189,248,.08)";
  const zStroke = showVerdict ? (ev.isStrike ? "#10b981" : "#3b82f6") : "#38bdf8";
  const chColor = ev.isStrike ? "#10b981" : "#3b82f6";

  const scalePxToCm = 0.36; 
  
  const dxVal = Math.abs(ev.realX) - (1.0 + zoneMargin);
  const dxCm = Math.abs(dxVal * (ZW / 2) * scalePxToCm);

  let dyCm = 0;
  let verticalStatus = "in"; 
  const pixelTB = effTopY;
  const pixelBB = effBotY;

  if (finalY < pixelTB) {
    verticalStatus = "high";
    dyCm = (pixelTB - finalY) * scalePxToCm;
  } else if (finalY > pixelBB) {
    verticalStatus = "low";
    dyCm = (finalY - pixelBB) * scalePxToCm;
  }

  return (
    <svg width="100%" height="100%" viewBox={`${vx} ${vy} ${vw} ${vh}`} className="transition-all duration-75">
      <polygon points={`${W / 2 - 52},${H - 34} ${W / 2 + 52},${H - 34} ${W / 2 + 52},${H - 21} ${W / 2},${H - 8} ${W / 2 - 52},${H - 21}`}
        fill="none" stroke="#38bdf8" strokeWidth="1.5" strokeDasharray="4,2" opacity={progress > zoomStartProg ? 0.15 : 0.45}/>

      {/* ABS 好球帶框架 */}
      <rect x={W / 2 - effL} y={effTopY} width={effL * 2} height={effBotY - effTopY}
        fill={zFill} stroke={zStroke} strokeWidth="2" style={{ transition: "all .4s" }}/>

      {/* 電子軌跡線條 */}
      {pts.length > 1 && (
        <polyline
          points={pts.map(p => `${p.x},${p.y}`).join(" ")}
          fill="none" stroke={ev.type?.color || "#fcd34d"} strokeWidth="2.2"
          style={{ filter: "drop-shadow(0 0 3px currentColor)" }} opacity={progress > zoomStartProg ? 0.35 : 0.95}/>
      )}

      {/* ABS 飛行棒球 */}
      <circle cx={bX} cy={bY} r={ballRadius} fill="#fff" style={{ filter: "drop-shadow(0 0 5px #fff)" }}/>

      {/* Done 挑戰結果量測標籤線 */}
      {done && showVerdict && (
        <g className="fade-in">
          {/* 精確落點準心 */}
          <circle cx={finalX} cy={finalY} r={ballRadius + 2.5} fill="none" stroke={chColor} strokeWidth="1.5" opacity=".8"/>
          <line x1={finalX - 35} y1={finalY}   x2={finalX + 35} y2={finalY}   stroke={chColor} strokeWidth="1"/>
          <line x1={finalX}   y1={finalY - 35} x2={finalX}   y2={finalY + 35} stroke={chColor} strokeWidth="1"/>

          {/* MLB 規格差距標籤拉線與測量數據 */}
          {ev.isStrike ? (
            <g>
              <line x1={finalX} y1={finalY} x2={W / 2 + (ev.realX > 0 ? effL : -effL)} y2={finalY} stroke="#10b981" strokeWidth="1.2" strokeDasharray="3,2" />
              <rect x={finalX - 32} y={finalY + ballRadius + 3} width="64" height="13" rx="2" fill="rgba(0,0,0,0.85)" stroke="#10b981" strokeWidth="0.8"/>
              <text x={finalX} y={finalY + ballRadius + 12} fontSize="7" fill="#10b981" fontWeight="bold" textAnchor="middle" fontFamily="monospace">
                內切 {Math.abs(dxVal * 21.5).toFixed(1)} cm
              </text>
            </g>
          ) : (
            <g>
              {/* 水平偏出 */}
              {dxVal > 0 && (
                <g>
                  <line x1={finalX} y1={finalY} x2={W / 2 + (ev.realX > 0 ? effL : -effL)} y2={finalY} stroke="#ef4444" strokeWidth="1.2" strokeDasharray="2,2" />
                  <rect x={finalX > W / 2 ? finalX + 12 : finalX - 62} y={finalY - 5} width="50" height="11" rx="2" fill="rgba(0,0,0,0.9)" stroke="#ef4444" strokeWidth="0.5"/>
                  <text x={finalX > W / 2 ? finalX + 37 : finalX - 37} y={finalY + 3} fontSize="6" fill="#ef4444" fontWeight="bold" textAnchor="middle" fontFamily="monospace">
                    偏外 {dxCm.toFixed(1)} cm
                  </text>
                </g>
              )}
              {/* 垂直偏出 */}
              {verticalStatus !== "in" && (
                <g>
                  <line x1={finalX} y1={finalY} x2={finalX} y2={verticalStatus === "high" ? pixelTB : pixelBB} stroke="#ef4444" strokeWidth="1.2" strokeDasharray="2,2" />
                  <rect x={finalX - 25} y={verticalStatus === "high" ? finalY - 14 : finalY + ballRadius + 2} width="50" height="11" rx="2" fill="rgba(0,0,0,0.9)" stroke="#ef4444" strokeWidth="0.5"/>
                  <text x={finalX} y={verticalStatus === "high" ? finalY - 6 : finalY + ballRadius + 10} fontSize="6" fill="#ef4444" fontWeight="bold" textAnchor="middle" fontFamily="monospace">
                    {verticalStatus === "high" ? "偏高" : "偏低"} {dyCm.toFixed(1)} cm
                  </text>
                </g>
              )}
            </g>
          )}

          {/* 數值看板 */}
          <g transform={`translate(${finalX - 35}, ${finalY - ballRadius - 16})`}>
            <rect x="0" y="0" width="70" height="13" rx="2.5" fill="rgba(0,0,0,0.85)" stroke={chColor} strokeWidth="0.8"/>
            <text x="35" y="9" fontSize="7" fill={chColor} fontFamily="monospace" fontWeight="bold" textAnchor="middle">
              GAP: {ev.realX.toFixed(2)}, {ev.realY.toFixed(2)}
            </text>
          </g>
        </g>
      )}
    </svg>
  );
}

